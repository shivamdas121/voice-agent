# =========================================================================================
# Real-estate Gemini Live voice agent — environment template.
# Copy this file to `.env` and fill in your real values. Do NOT put real secrets here.
# =========================================================================================

# --- LiveKit Credentials (https://cloud.livekit.io/) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- Gemini Live API (STT + LLM + TTS in one model) ---
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key
# Optional overrides (defaults set in config.py)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VOICE=Aoede
GEMINI_TEMPERATURE=0.8

# --- Scenario / brand ---
DEVELOPER_NAME=Skyline Developers
AGENT_NAME=Priya

# --- Booking (n8n webhook) ---
# Production URL of your n8n "Webhook" node that books the site visit and responds with the slot.
BOOKING_WEBHOOK_URL=https://your-n8n-host/webhook/site-visit
BOOKING_TIMEOUT=10

# --- Trigger server (form -> call) ---
# Shared secret the form/webhook must send as the `x-api-key` header to place a call.
TRIGGER_API_KEY=change-me-to-a-long-random-string

# --- Vobiz / SIP Trunking ---
VOBIZ_SIP_TRUNK_ID=your_trunk_id
OUTBOUND_TRUNK_ID=your_trunk_id  # Usually same as above
VOBIZ_SIP_DOMAIN=your_sip_domain
VOBIZ_USERNAME=your_sip_username
VOBIZ_PASSWORD=your_sip_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
